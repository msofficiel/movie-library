{% extends 'base.html.twig' %}

{% block title %}Liste des films{% endblock %}

{% block body %}
<div class="container">
    <h1>Vidéothèque - Liste des films</h1>

    <form method="get" action="{{ path('app_movie_index') }}">
        <input type="text" name="search" placeholder="Rechercher un titre..." value="{{ app.request.query.get('search') }}">
        <button type="submit">Rechercher</button>
    </form>

    <p><a href="{{ path('app_movie_new') }}">+ Ajouter un film</a></p>

    <table>
        <thead>
            <tr>
                <th>Titre</th>
                <th>Réalisateur</th>
                <th>Année</th>
                <th>Genre</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for movie in movies %}
            <tr>
                <td>{{ movie.title }}</td>
                <td>{{ movie.director }}</td>
                <td>{{ movie.releaseYear }}</td>
                <td>{{ movie.genre }}</td>
                <td>
                    <a href="{{ path('app_movie_show', {'id': movie.id}) }}">Voir</a> |
                    <a href="{{ path('app_movie_edit', {'id': movie.id}) }}">Modifier</a> |
                    {{ include('movie/_delete_form.html.twig') }}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">Aucun film enregistré.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
